-- HOOKS
-- ============================================================
local oldNamecall
oldNamecall = hookfunction(getrawmetatable(game).__namecall, function(self, ...)
    local method = getnamecallmethod()

    if method == "FireServer" and fsEnabled then
        print("[SPY] FireServer:", self.Name)
        printArgs({...}, select('#', ...))
    elseif method == "InvokeServer" and oceEnabled then
        print("[SPY] InvokeServer:", self.Name)
        printArgs({...}, select('#', ...))
    end

    return oldNamecall(self, ...)
end)
