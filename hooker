-- ============================================================
-- SERIALIZATION HELPERS
-- ============================================================
local function serializeTable(tbl, indent)
    indent = indent or 1
    local result = "{\n"
    local prefix = string.rep("  ", indent)

    for k, v in pairs(tbl) do
        local key = type(k) == "string" and k or "[" .. tostring(k) .. "]"
        if type(v) == "table" then
            result = result .. prefix .. key .. " = " .. serializeTable(v, indent + 1)
        else
            result = result .. prefix .. key .. " = " .. tostring(v) .. "\n"
        end
    end

    return result .. string.rep("  ", indent - 1) .. "}\n"
end

local function dumpBuffer(buf)
    local len = buffer.len(buf)
    if len < 1 then
        print("  [buffer] empty")
        return
    end

    local packetId = buffer.readu8(buf, 0)
    local hexParts = {}
    for i = 1, len - 1 do
        hexParts[#hexParts + 1] = string.format("%02X", buffer.readu8(buf, i))
    end

    print(string.format("  [buffer] len=%d  packetId=%d", len, packetId))
    print("  [payload hex] " .. table.concat(hexParts, " "))
end

local function printArgs(args, count)
    for i = 1, count do
        local v = args[i]
        if type(v) == "buffer" then
            print("  [" .. i .. "] = <buffer>")
            dumpBuffer(v)
        elseif type(v) == "table" then
            print("  [" .. i .. "] = " .. serializeTable(v))
        else
            print("  [" .. i .. "] =", v)
        end
    end
end

-- ============================================================
-- LOG CAPTURE + CLIPBOARD  (toggle with "B")
-- ============================================================
local logBuffer       = {}
local captureEnabled  = false
local oldPrint         = print

-- Wrap print so every print() call (including ones above) also gets captured.
-- Since printArgs/dumpBuffer/addLog all call the global `print`, reassigning
-- it here is enough to capture everything they output, with no other edits.
print = function(...)
    local n = select('#', ...)
    local parts = {}
    for i = 1, n do
        parts[i] = tostring(select(i, ...))
    end
    local line = table.concat(parts, "\t")

    oldPrint(line)

    if captureEnabled then
        table.insert(logBuffer, line)
    end
end

local function copyLogsToClipboard()
    if #logBuffer == 0 then
        oldPrint("[CAPTURE] Nothing captured yet.")
        return
    end

    local full = table.concat(logBuffer, "\n")

    if setclipboard then
        setclipboard(full)
        oldPrint("[CAPTURE] Copied " .. #logBuffer .. " lines to clipboard.")
    elseif toclipboard then
        toclipboard(full)
        oldPrint("[CAPTURE] Copied " .. #logBuffer .. " lines to clipboard (toclipboard).")
    else
        oldPrint("[CAPTURE] No clipboard function available on this executor.")
    end

    table.clear(logBuffer)  -- <-- added: wipe buffer after copying
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end

    if input.KeyCode == Enum.KeyCode.B then
        captureEnabled = not captureEnabled

        if captureEnabled then
            oldPrint("[CAPTURE] Started — logging prints to buffer.")
        else
            oldPrint("[CAPTURE] Stopped. Copying to clipboard now...")
            copyLogsToClipboard()
        end
    end
end)

