local function ensureFolder(path)
    if not isfolder(path) then
        makefolder(path)
        print("[RECORDER] Created folder: " .. path)
    end
end

local function fileExists(strategyName)
    local path = "TDSRecord/strat/" .. strategyName .. ".txt"
    return isfile(path), path
end

local function saveRecording(strategyName, content)
    if not strategyName or strategyName == "" then
        print("[RECORDER] ERROR: Strategy name is empty!")
        return false
    end
    ensureFolder("TDSRecord")
    ensureFolder("TDSRecord/strat")
    local filename = "TDSRecord/strat/" .. strategyName .. ".txt"
    pcall(function()
        writefile(filename, content)
        print("[RECORDER] Recording saved to: " .. filename)
    end)
end

