-- ============================================================
-- Upgrade Level Verification
-- ============================================================
-- Reads the tower model's Upgrades folder to determine its actual
-- current level: model.Upgrades.<level>.<part/meshpart> with
-- Transparency == 0 at the active level, 1 everywhere else.
local function getActualLevel(troop)
    local upgrades = troop and troop:FindFirstChild("Upgrades")
    if not upgrades then return nil end

    for _, levelFolder in ipairs(upgrades:GetChildren()) do
        local levelNum = tonumber(levelFolder.Name)
        if levelNum then
            for _, part in ipairs(levelFolder:GetDescendants()) do
                if part:IsA("BasePart") then
                    if part.Transparency == 0 then
                        return levelNum
                    end
                    break -- one sample part per folder is enough
                end
            end
        end
    end

    return nil
end

-- Fires one upgrade call and verifies the tower actually reached
-- expectedLevel via getActualLevel, retrying on mismatch. This is the
-- "do one upgrade" primitive -- callers must ensure only one of these
-- runs at a time per tower (see enqueueUpgrade below), otherwise two
-- concurrent attempts targeting different expectedLevels fight over
-- the same troop and neither ever confirms.
local function attemptUpgrade(id, troop, path, expectedLevel)
    local maxRetries = 5
    local retryDelay = 0.5

    for attempt = 1, maxRetries do
        if not PlaybackSystem.isPlaying then return end

        pcall(function()
            TroopsChannel:InvokeServer("Upgrade", "Set", { Troop = troop, Path = path })
        end)

        task.wait(retryDelay)

        local actualLevel = getActualLevel(troop)
        if actualLevel == expectedLevel then
            print("[PLAYBACK] Confirmed upgrade id=" .. id .. " -> level " .. expectedLevel)
            return
        end

        warn("[PLAYBACK] Upgrade id=" .. id .. " not confirmed (got " ..
            tostring(actualLevel) .. ", expected " .. expectedLevel ..
            "), retry " .. attempt .. "/" .. maxRetries)
    end

    warn("[PLAYBACK] FAILED to confirm upgrade id=" .. id .. " -> level " ..
        expectedLevel .. " after " .. maxRetries .. " attempts")
end

-- Drains PlaybackSystem.upgradeQueues[id] one entry at a time. Only
-- one worker per tower id is ever running (guarded by
-- upgradeWorkerActive), so upgrade events for the SAME tower are
-- strictly serialized -- event N+1's upgrade only starts after event
-- N's has fully resolved (confirmed or exhausted retries). Different
-- towers still run fully in parallel since each id gets its own
-- worker/queue.
local function runUpgradeWorker(id, troop)
    if PlaybackSystem.upgradeWorkerActive[id] then
        return -- a worker for this id is already draining the queue
    end
    PlaybackSystem.upgradeWorkerActive[id] = true

    task.spawn(function()
        local queue = PlaybackSystem.upgradeQueues[id]
        while queue and #queue > 0 do
            if not PlaybackSystem.isPlaying then break end
            local job = table.remove(queue, 1)
            attemptUpgrade(id, troop, job.path, job.expectedLevel)
        end
        PlaybackSystem.upgradeWorkerActive[id] = nil
    end)
end

-- Adds an upgrade job to this tower's queue and ensures a worker is
-- running to drain it. Safe to call concurrently for different ids;
-- for the same id, jobs are processed strictly in the order enqueued.
local function enqueueUpgrade(id, troop, path, expectedLevel)
    PlaybackSystem.upgradeQueues[id] = PlaybackSystem.upgradeQueues[id] or {}
    table.insert(PlaybackSystem.upgradeQueues[id], { path = path, expectedLevel = expectedLevel })
    runUpgradeWorker(id, troop)
end

-- ============================================================
-- Placement Verification & Retry
-- ============================================================
-- TroopsChannel:InvokeServer("Place", ...) returns an Instance on
-- success, or a string error message on failure (e.g. "not enough
-- money"). Retries on failure since every later event for this id
-- (upgrades, sells, abilities...) depends on placedTowers[id] being
-- set -- a single missed placement would silently break the rest of
-- that tower's timeline.
local function placeTowerWithRetry(id, towerName, pos)
    PlaybackSystem.pendingPlacements[id] = true

    task.spawn(function()
        local maxRetries = 8
        local retryDelay = 1.0

        for attempt = 1, maxRetries do
            if not PlaybackSystem.isPlaying then
                PlaybackSystem.pendingPlacements[id] = nil
                return
            end

            local ok, result = pcall(function()
                return TroopsChannel:InvokeServer("Place", {
                    Position = pos,
                    Rotation = CFrame.Angles(0, 0, 0),
                }, towerName)
            end)

            if ok and result and typeof(result) == "Instance" then
                PlaybackSystem.placedTowers[id]      = result
                PlaybackSystem.pendingPlacements[id] = nil
                print("[PLAYBACK] Placed " .. towerName .. " (id=" .. id .. ") on attempt " .. attempt)
                return
            end

            -- result is the server's string reason on failure (e.g. "not enough money")
            warn("[PLAYBACK] Place failed for " .. towerName .. " (id=" .. id .. "): " ..
                tostring(result) .. " -- retry " .. attempt .. "/" .. maxRetries)

            task.wait(retryDelay)
        end

        PlaybackSystem.pendingPlacements[id] = nil
        PlaybackSystem.failedPlacements[id]  = true
        warn("[PLAYBACK] GIVING UP on placing " .. towerName .. " (id=" .. id ..
            ") after " .. maxRetries .. " attempts -- later events for this id will be skipped")
    end)
end

-- Other event branches (upgrade/sell/target/ability/option) call this
-- instead of reading PlaybackSystem.placedTowers[id] directly, so they
-- wait out an in-progress placement retry rather than failing the
-- instant they're checked (which would happen almost every time, since
-- those events follow PLACE_TOWER by mere fractions of a second).
local function waitForTower(id)
    if PlaybackSystem.failedPlacements[id] then
        return nil -- placement already permanently gave up, don't bother waiting
    end

    while PlaybackSystem.pendingPlacements[id] and PlaybackSystem.isPlaying do
        task.wait(0.1)
    end

    return PlaybackSystem.placedTowers[id]
end

local function executeEvent(event)
    local data = event.data

    if event.type == "PLACE_TOWER" then
        local pos       = parseVector3(data.position or "0, 0, 0")
        local towerName = data.name or "Unknown"
        local id        = tonumber(data.id) or -1
        placeTowerWithRetry(id, towerName, pos)

    elseif event.type == "UPGRADE_TOWER" then
        local id    = tonumber(data.id) or -1
        local path  = tonumber(data.path) or 1

        -- Increment the counter synchronously, in the same order events
        -- are read from the recording -- this fixes expectedLevel to the
        -- correct value before anything async happens. If this were done
        -- inside the spawned coroutine below, two close-together events
        -- for the same tower could race and grab counter values out of
        -- the order they appear in the recording.
        PlaybackSystem.upgradeCounts[id] = (PlaybackSystem.upgradeCounts[id] or 0) + 1
        local expectedLevel = PlaybackSystem.upgradeCounts[id]

        task.spawn(function()
            local troop = waitForTower(id)
            if troop then
                enqueueUpgrade(id, troop, path, expectedLevel)
            else
                warn("[PLAYBACK] Cannot upgrade, tower id=" .. id .. " not found")
            end
        end)

    elseif event.type == "SELL_TOWER" then
        local id = tonumber(data.id) or -1
        task.spawn(function()
            local troop = waitForTower(id)
            if troop then
                pcall(function() TroopsChannel:InvokeServer("Sell", { Troop = troop }) end)
                print("[PLAYBACK] Sold tower id=" .. id)
                PlaybackSystem.placedTowers[id] = nil
            else
                warn("[PLAYBACK] Cannot sell, tower id=" .. id .. " not found")
            end
        end)

    elseif event.type == "SET_TARGET" then
        local id     = tonumber(data.id) or -1
        local target = data.target or "First"
        task.spawn(function()
            local troop = waitForTower(id)
            if troop then
                pcall(function() TroopsChannel:InvokeServer("Target", "Set", { Troop = troop, Target = target }) end)
                print("[PLAYBACK] Set target tower id=" .. id .. " -> " .. target)
            end
        end)

    elseif event.type == "USE_ABILITY" then
        local id      = tonumber(data.id) or -1
        local ability = data.ability or "Unknown"
        task.spawn(function()
            local troop = waitForTower(id)
            if troop then
                pcall(function() TroopsChannel:InvokeServer("Abilities", "Activate", { Name = ability, Troop = troop, Data = {} }) end)
                print("[PLAYBACK] Used ability " .. ability .. " on tower id=" .. id)
            end
        end)

    elseif event.type == "SET_OPTION" then
        local id          = tonumber(data.id) or -1
        local optionName  = data.option or "Unknown"
        local optionValue = data.value
        task.spawn(function()
            local troop = waitForTower(id)
            if troop then
                pcall(function() TroopsChannel:InvokeServer("Option", "Set", { Troop = troop, Name = optionName, Value = optionValue }) end)
                print("[PLAYBACK] Set option " .. optionName .. " on tower id=" .. id)
            end
        end)

    elseif event.type == "SKIP_VOTE" then
        autoSkip("PLAYER")
    end
end

runPlayback = function()
    local myRunId = PlaybackSystem.runId
    local events  = PlaybackSystem.currentEvents
    if not events then return end
    local matchStart = PlaybackSystem.matchStart
    for _, event in ipairs(events) do
        if not PlaybackSystem.isPlaying then return end
        if PlaybackSystem.runId ~= myRunId then
            -- a newer startPlayback call has superseded this run; stop
            -- silently so we never have two runPlayback loops firing
            -- events over the same/overlapping timeline at once.
            return
        end
        local waitTime = event.time - (tick() - matchStart)
        if waitTime > 0 then task.wait(waitTime) end
        if not PlaybackSystem.isPlaying then return end
        if PlaybackSystem.runId ~= myRunId then return end
        executeEvent(event)
    end
    print("[PLAYBACK] Finished executing all events.")
end

monitorMatchEndPlay = function()
    if PlaybackSystem.matchEndConn then
        PlaybackSystem.matchEndConn:Disconnect()
        PlaybackSystem.matchEndConn = nil
    end
    while PlaybackSystem.isPlaying do
        local playerGui    = localPlayer:WaitForChild("PlayerGui")
        local rewardsFrame = playerGui:FindFirstChild("ReactGameNewRewards")
        if rewardsFrame then
            local frame = rewardsFrame:FindFirstChild("Frame")
            if frame then
                local gameOver = frame:FindFirstChild("gameOver")
                if gameOver then
                    PlaybackSystem.matchEndConn = gameOver:GetPropertyChangedSignal("Visible"):Connect(function()
                        if gameOver.Visible and PlaybackSystem.isPlaying then
                            print("[PLAYER] Match ended!")
                            if PlaybackSystem.loopEnabled then
                                print("[PLAYER] Loop enabled, restarting playback...")
                                syncPlayUI("RESTARTING")
                                task.wait(3)
                                if PlaybackSystem.isPlaying then
                                    startPlayback(PlaybackSystem.currentStrategyName, true)
                                    syncPlayUI()
                                end
                            else
                                stopPlayback()
                            end
                        end
                    end)
                    return
                end
            end
        end
        task.wait(0.5)
    end
end

startPlayback = function(strategyName, skipFileCheck)
    -- Reject a fresh external play request while a session is already
    -- active. The loop-restart path passes skipFileCheck=true and is
    -- allowed through even though isPlaying is still true at that point
    -- -- that's an intentional restart, not an accidental double-press.
    if PlaybackSystem.isPlaying and not skipFileCheck then
        warn("[PLAYER] startPlayback called while already playing -- ignoring")
        return false, "Already playing"
    end

    if not skipFileCheck then
        local events, err = loadRecording(strategyName)
        if not events then
            warn("[PLAYER] " .. err)
            return false, err
        end
        PlaybackSystem.currentEvents       = events
        PlaybackSystem.currentStrategyName = strategyName
    end

    -- New generation: any runPlayback coroutine still alive from a
    -- previous call (shouldn't normally happen now, but this is the
    -- hard guarantee) will see its captured runId no longer match and
    -- stop itself instead of continuing to fire events in parallel.
    PlaybackSystem.runId = PlaybackSystem.runId + 1

    PlaybackSystem.isPlaying          = true
    PlaybackSystem.placedTowers       = {}
    PlaybackSystem.upgradeCounts      = {}
    PlaybackSystem.pendingPlacements  = {}
    PlaybackSystem.failedPlacements   = {}
    PlaybackSystem.upgradeQueues      = {}
    PlaybackSystem.upgradeWorkerActive = {}
    print("[PLAYER] Starting playback: " .. strategyName)
    print("[PLAYER] Triggering auto-skip to start match...")

    -- Snapshot matchStart BEFORE the wait/skip sequence, mirroring
    -- how the recorder captures startTime before its own wait/skip --
    -- keeps both clocks' T+0 anchored to the same logical point.
    PlaybackSystem.matchStart = tick()

    task.wait(0.2)
    autoSkip("PLAYER")
    task.spawn(runPlayback)
    task.spawn(monitorMatchEndPlay)
    return true
end

stopPlayback = function()
    PlaybackSystem.isPlaying = false
    if PlaybackSystem.matchEndConn then
        PlaybackSystem.matchEndConn:Disconnect()
        PlaybackSystem.matchEndConn = nil
    end
    print("[PLAYER] Playback stopped.")
    syncPlayUI()
end

