-- ============================================================
-- Remote Hooks (Recorder)
-- ============================================================
local oldNamecall
oldNamecall = hookfunction(getrawmetatable(game).__namecall, function(self, ...)
    local method = getnamecallmethod()
    local result = oldNamecall(self, ...)

    if not RecordingSystem.isRecording then
        return result
    end

    local args = { ... }

    if method == "InvokeServer" then
        if args[1] == "Troops" then

            if args[2] == "Place" then
                local towerName = args[4] or "Unknown"
                local index
                if result and typeof(result) == "Instance" then
                    index = registerTower(result)
                end
                recordEvent("PLACE_TOWER", {
                    id       = index or -1,
                    name     = towerName,
                    position = args[3] and tostring(args[3].Position) or "Unknown",
                })

            elseif args[2] == "Upgrade" and args[3] == "Set" then
                local troop = args[4] and args[4].Troop
                local path  = args[4] and args[4].Path or 0
                recordEvent("UPGRADE_TOWER", { id = getTowerIndex(troop), path = path })

            elseif args[2] == "Sell" then
                local troop = args[3] and args[3].Troop
                recordEvent("SELL_TOWER", { id = getTowerIndex(troop) })

            elseif args[2] == "Target" and args[3] == "Set" then
                local troop  = args[4] and args[4].Troop
                local target = args[4] and args[4].Target or "Unknown"
                recordEvent("SET_TARGET", { id = getTowerIndex(troop), target = target })

            elseif args[2] == "Abilities" and args[3] == "Activate" then
                local troop       = args[4] and args[4].Troop
                local abilityName = args[4] and args[4].Name or "Unknown"
                local data        = args[4] and args[4].Data
                local dataStr     = "{}"
                if data and next(data) then
                    local parts = {}
                    for k, v in pairs(data) do
                        table.insert(parts, tostring(k) .. "=" .. tostring(v))
                    end
                    dataStr = "{ " .. table.concat(parts, ", ") .. " }"
                end
                recordEvent("USE_ABILITY", { id = getTowerIndex(troop), ability = abilityName, data = dataStr })

            elseif args[2] == "Option" and args[3] == "Set" then
                local troop       = args[4] and args[4].Troop
                local optionName  = args[4] and args[4].Name or "Unknown"
                local optionValue = args[4] and args[4].Value
                recordEvent("SET_OPTION", { id = getTowerIndex(troop), option = optionName, value = tostring(optionValue) })
            end

        elseif args[1] == "Voting" and args[2] == "Skip" then
            recordEvent("SKIP_VOTE", { action = "Skip" })
        end
    end

    return result
end)

