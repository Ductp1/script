local function isMatchEnded()
    local playerGui    = localPlayer:WaitForChild("PlayerGui")
    local rewardsFrame = playerGui:FindFirstChild("ReactGameNewRewards")
    if rewardsFrame then
        local frame = rewardsFrame:FindFirstChild("Frame")
        if frame then
            local gameOver = frame:FindFirstChild("gameOver")
            if gameOver then return gameOver.Visible end
        end
    end
    return false
end

local function autoSkip(tag)
    pcall(function()
        local votingRemote = ReplicatedStorage:WaitForChild("RemoteFunction")
        votingRemote:InvokeServer("Voting", "Skip")
        print("[" .. tag .. "] Auto-skip triggered!")
    end)
end

