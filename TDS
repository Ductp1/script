local RecordingSystem = {
    isRecording      = false,
    startTime        = 0,
    events           = {},
    placementCounter = 0,
    towerInstances   = {},
    matchEndConn     = nil,
    monitorActive    = false,
}

local startRecording, stopRecording, monitorMatchEndRec, exportRecording

-- Set by the GUI construction code further down, once the buttons/labels
-- exist. Called whenever recording state changes -- whether from a button
-- click or an automatic stop on match end -- so the UI never goes stale.
local syncRecordUI = function() end

local function getElapsedTime()
    if not RecordingSystem.isRecording then return 0 end
    return tick() - RecordingSystem.startTime
end

local function recordEvent(eventType, data)
    if not RecordingSystem.isRecording then return end
    table.insert(RecordingSystem.events, {
        type = eventType,
        time = getElapsedTime(),
        data = data,
    })
    print("[RECORDING] " .. eventType .. " @ " .. string.format("%.2f", getElapsedTime()) .. "s")
end

local function registerTower(model)
    RecordingSystem.placementCounter = RecordingSystem.placementCounter + 1
    RecordingSystem.towerInstances[model] = RecordingSystem.placementCounter
    return RecordingSystem.placementCounter
end

local function getTowerIndex(model)
    return model and RecordingSystem.towerInstances[model] or -1
end

monitorMatchEndRec = function()
    RecordingSystem.monitorActive = true
    while RecordingSystem.monitorActive do
        if RecordingSystem.matchEndConn then
            RecordingSystem.matchEndConn:Disconnect()
            RecordingSystem.matchEndConn = nil
        end
        local playerGui    = localPlayer:WaitForChild("PlayerGui")
        local rewardsFrame = playerGui:FindFirstChild("ReactGameNewRewards")
        if rewardsFrame then
            local frame = rewardsFrame:FindFirstChild("Frame")
            if frame then
                local gameOver = frame:FindFirstChild("gameOver")
                if gameOver then
                    RecordingSystem.matchEndConn = gameOver:GetPropertyChangedSignal("Visible"):Connect(function()
                        if gameOver.Visible and RecordingSystem.isRecording then
                            print("[RECORDER] Match ended! Auto-stopping recording...")
                            stopRecording()
                        end
                    end)
                    return
                end
            end
        end
        task.wait(0.5)
    end
end

startRecording = function()
    RecordingSystem.isRecording      = true
    RecordingSystem.startTime        = tick()
    RecordingSystem.events           = {}
    RecordingSystem.placementCounter = 0
    RecordingSystem.towerInstances   = {}
    print("[RECORDER] Recording started!")
    print("[RECORDER] Triggering auto-skip to start match...")
    task.wait(0.2)
    autoSkip("RECORDER")
    task.spawn(monitorMatchEndRec)
end

stopRecording = function()
    RecordingSystem.monitorActive = false
    RecordingSystem.isRecording   = false
    if RecordingSystem.matchEndConn then
        RecordingSystem.matchEndConn:Disconnect()
        RecordingSystem.matchEndConn = nil
    end
    print("[RECORDER] Recording stopped! Total events: " .. #RecordingSystem.events)
    syncRecordUI()
end

exportRecording = function()
    local output = "=== TOWER DEFENSE RECORDING ===\n"
    output = output .. "Total Events: " .. #RecordingSystem.events .. "\n"
    local lastTime = RecordingSystem.events[#RecordingSystem.events]
    output = output .. "Recording Duration: " .. string.format("%.2f", lastTime and lastTime.time or 0) .. "s\n"
    output = output .. "================================\n\n"
    for i, event in ipairs(RecordingSystem.events) do
        output = output .. "[" .. i .. "] T+" .. string.format("%.2f", event.time) .. "s - " .. event.type .. "\n"
        if event.data then
            for k, v in pairs(event.data) do
                output = output .. "    " .. k .. " = " .. tostring(v) .. "\n"
            end
        end
        output = output .. "\n"
    end
    return output
end

-- ============================================================
-- Playback System
-- ============================================================
local function parseRecording(content)
    local events = {}
    for line in content:gmatch("[^\r\n]+") do
        local idx, time, eventType = line:match("^%[(%d+)%]%s+T%+([%d%.]+)s%s+%-%s+([%u_]+)")
        if idx and time and eventType then
            table.insert(events, { time = tonumber(time), type = eventType, data = {} })
        else
            local k, v = line:match("^%s*(%a+)%s*=%s*(.+)$")
            if k and #events > 0 then
                events[#events].data[k] = v
            end
        end
    end
    return events
end

local function loadRecording(strategyName)
    local exists, path = fileExists(strategyName)
    if not exists then return nil, "File does not exist: " .. path end
    local ok, content = pcall(readfile, path)
    if not ok then return nil, "Failed to read file" end
    local events = parseRecording(content)
    if #events == 0 then return nil, "No events found in file" end
    return events
end

local function parseVector3(str)
    local x, y, z = str:match("([%-%d%.]+),%s*([%-%d%.]+),%s*([%-%d%.]+)")
    if x and y and z then return Vector3.new(tonumber(x), tonumber(y), tonumber(z)) end
    return Vector3.new(0, 0, 0)
end

local PlaybackSystem = {
    isPlaying           = false,
    loopEnabled         = false,
    currentEvents       = nil,
    currentStrategyName = nil,
    placedTowers        = {},
    matchEndConn        = nil,
    matchStart          = 0,
    upgradeCounts       = {},   -- id -> number of upgrade events issued so far this playback
    pendingPlacements   = {},   -- id -> true while a placement retry loop is still running
    failedPlacements    = {},   -- id -> true once a placement permanently gives up
    upgradeQueues       = {},   -- id -> array of {path, expectedLevel} waiting to be processed in order
    upgradeWorkerActive  = {},  -- id -> true while a worker coroutine is draining that tower's queue
    runId               = 0,    -- bumped every startPlayback call; lets a stale runPlayback notice it's been superseded
}

local startPlayback, stopPlayback, monitorMatchEndPlay, runPlayback

