-- Same pattern as syncRecordUI: stopPlayback()/loop-restart call this
-- so STOP/PLAY state and the status label stay correct even when the
-- stop was triggered automatically by match end, not a button click.
syncPlayUI = function(overrideStatus)
    if overrideStatus == "RESTARTING" then
        PlayStatusLabel.Text       = "Status: RESTARTING..."
        PlayStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        return
    end

    if PlaybackSystem.isPlaying then
        PlayStatusLabel.Text       = "Status: PLAYING"
        PlayStatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        PlayStatusLabel.Text       = "Status: STOPPED"
        PlayStatusLabel.TextColor3 = Color3.fromRGB(200, 200, 100)
    end
end

LoopButton.MouseButton1Click:Connect(function()
    PlaybackSystem.loopEnabled       = not PlaybackSystem.loopEnabled
    LoopButton.Text                  = PlaybackSystem.loopEnabled and "ON" or "OFF"
    LoopButton.BackgroundColor3      = PlaybackSystem.loopEnabled
        and Color3.fromRGB(0, 150, 80)
        or  Color3.fromRGB(160, 80, 0)
end)

PlayButton.MouseButton1Click:Connect(function()
    local strategyName = PlayStratBox.Text
    if strategyName == "" then
        PlayStatusLabel.Text      = "Status: ENTER A NAME"
        PlayStatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        return
    end
    local exists, path = fileExists(strategyName)
    if not exists then
        PlayStatusLabel.Text       = "Status: FILE NOT FOUND"
        PlayStatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        print("[PLAYER] File does not exist: " .. path)
        return
    end
    if PlaybackSystem.isPlaying then
        PlayStatusLabel.Text       = "Status: ALREADY PLAYING"
        PlayStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
        return
    end
    local success, err = startPlayback(strategyName)
    if success then
        syncPlayUI()
    else
        PlayStatusLabel.Text       = "Status: ERROR"
        PlayStatusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        print("[PLAYER] " .. tostring(err))
    end
end)

